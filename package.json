{
  "name": "image-processing-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AI全栈",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n server,client -c blue,green \"pnpm dev:server\" \"wait-on http://127.0.0.1:9000 && pnpm dev:client\"",
    "dev:client": "pnpm --filter @app/frontend dev",
    "dev:server": "cd backend && python -m uvicorn app:app --reload --host 127.0.0.1 --port 9000",
    "build": "pnpm --filter @app/frontend build",
    "preview": "pnpm --filter @app/frontend preview",
    "install:python": "pip install -r backend/requirements.txt",
    "install:all": "pnpm install && pnpm install:python",
    "gen:types": "cd backend && python scripts/generate_types.py"
  },
  "devDependencies": {
    "@oxc-parser/binding-win32-x64-msvc": "^0.104.0",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
